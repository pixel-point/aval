{
  "name": "rendered-motion-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @rendered-motion/player-web && npm run build -w @rendered-motion/playground",
    "dev": "npm run dev -w @rendered-motion/playground",
    "test": "npm run test:unit && npm run test:browser",
    "test:unit": "vitest run",
    "test:browser": "playwright test",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
