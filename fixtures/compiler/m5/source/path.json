{
  "projectVersion": "0.1",
  "profile": "avc-annexb-opaque-v0",
  "canvas": {
    "width": 32,
    "height": 32,
    "fit": "contain",
    "pixelAspect": [1, 1],
    "colorSpace": "srgb"
  },
  "frameRate": { "numerator": 30, "denominator": 1 },
  "sources": [
    {
      "id": "frames",
      "type": "png-sequence",
      "directory": "path",
      "prefix": "frame-",
      "digits": 4,
      "suffix": ".png",
      "firstNumber": 0,
      "frameCount": 8
    }
  ],
  "renditions": [
    {
      "id": "opaque.1x",
      "codedWidth": 32,
      "codedHeight": 32,
      "bitrate": { "average": 2000000, "peak": 3000000 }
    }
  ],
  "units": [
    {
      "id": "active-body",
      "kind": "body",
      "source": "frames",
      "range": [6, 8],
      "playback": "loop",
      "ports": [
        { "id": "default", "entryFrame": 0, "portalFrames": [1] }
      ]
    },
    {
      "id": "bridge",
      "kind": "bridge",
      "source": "frames",
      "range": [4, 6]
    },
    {
      "id": "idle-body",
      "kind": "body",
      "source": "frames",
      "range": [2, 4],
      "playback": "loop",
      "ports": [
        { "id": "default", "entryFrame": 0, "portalFrames": [1] }
      ]
    },
    {
      "id": "intro",
      "kind": "one-shot",
      "source": "frames",
      "range": [0, 2]
    }
  ],
  "initialState": "idle",
  "states": [
    { "id": "active", "bodyUnit": "active-body" },
    { "id": "idle", "bodyUnit": "idle-body", "initialUnit": "intro" }
  ],
  "edges": [
    {
      "id": "idle-active",
      "from": "idle",
      "to": "active",
      "trigger": { "type": "event", "name": "hover" },
      "start": {
        "type": "portal",
        "sourcePort": "default",
        "targetPort": "default",
        "maxWaitFrames": 1
      },
      "transition": { "kind": "locked", "unit": "bridge" },
      "continuity": "exact-authored"
    }
  ],
  "bindings": [
    { "source": "pointer.enter", "event": "hover" }
  ]
}
