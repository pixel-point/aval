{
  "projectVersion": "1.0",
  "alpha": "opaque",
  "canvas": {
    "width": 512,
    "height": 512,
    "fit": "contain",
    "pixelAspect": [1, 1],
    "colorSpace": "srgb"
  },
  "frameRate": { "numerator": 24, "denominator": 1 },
  "sources": [
    {
      "id": "orb",
      "type": "video",
      "path": "source/kinetic-orb.mp4",
      "timing": { "mode": "exact" }
    }
  ],
  "encodings": [
    {
      "codec": "h264",
      "preset": "medium",
      "renditions": [
        { "id": "video.1x", "width": 512, "height": 512, "crf": 16 }
      ]
    }
  ],
  "units": [
    {
      "id": "intro",
      "kind": "one-shot",
      "source": "orb",
      "range": [0, 24]
    },
    {
      "id": "idle-loop",
      "kind": "body",
      "source": "orb",
      "range": [24, 48],
      "playback": "loop",
      "ports": [
        {
          "id": "default",
          "entryFrame": 0,
          "portalFrames": [2, 5, 8, 11, 14, 17, 20, 23]
        }
      ]
    },
    {
      "id": "hover-in",
      "kind": "body",
      "source": "orb",
      "range": [48, 60],
      "playback": "finite",
      "ports": [
        { "id": "default", "entryFrame": 0, "portalFrames": [11] }
      ]
    },
    {
      "id": "hover-loop",
      "kind": "body",
      "source": "orb",
      "range": [60, 84],
      "playback": "loop",
      "ports": [
        {
          "id": "default",
          "entryFrame": 0,
          "portalFrames": [2, 5, 8, 11, 14, 17, 20, 23]
        }
      ]
    },
    {
      "id": "hover-out",
      "kind": "body",
      "source": "orb",
      "range": [84, 96],
      "playback": "finite",
      "ports": [
        { "id": "default", "entryFrame": 0, "portalFrames": [11] }
      ]
    }
  ],
  "initialState": "idle",
  "states": [
    { "id": "idle", "bodyUnit": "idle-loop", "initialUnit": "intro" },
    { "id": "entering", "bodyUnit": "hover-in" },
    { "id": "hover", "bodyUnit": "hover-loop" },
    { "id": "exiting", "bodyUnit": "hover-out" }
  ],
  "edges": [
    {
      "id": "idle.entering",
      "from": "idle",
      "to": "entering",
      "trigger": { "type": "event", "name": "hover.enter" },
      "start": {
        "type": "portal",
        "sourcePort": "default",
        "targetPort": "default",
        "maxWaitFrames": 2
      },
      "continuity": "exact-authored"
    },
    {
      "id": "entering.hover",
      "from": "entering",
      "to": "hover",
      "trigger": { "type": "completion" },
      "start": {
        "type": "finish",
        "targetPort": "default",
        "maxWaitFrames": 11
      },
      "continuity": "exact-authored"
    },
    {
      "id": "entering.exiting",
      "from": "entering",
      "to": "exiting",
      "trigger": { "type": "event", "name": "hover.leave" },
      "start": {
        "type": "finish",
        "targetPort": "default",
        "maxWaitFrames": 11
      },
      "continuity": "exact-authored"
    },
    {
      "id": "hover.exiting",
      "from": "hover",
      "to": "exiting",
      "trigger": { "type": "event", "name": "hover.leave" },
      "start": {
        "type": "portal",
        "sourcePort": "default",
        "targetPort": "default",
        "maxWaitFrames": 2
      },
      "continuity": "exact-authored"
    },
    {
      "id": "exiting.idle",
      "from": "exiting",
      "to": "idle",
      "trigger": { "type": "completion" },
      "start": {
        "type": "finish",
        "targetPort": "default",
        "maxWaitFrames": 11
      },
      "continuity": "exact-authored"
    }
  ],
  "bindings": [
    { "source": "engagement.on", "event": "hover.enter" },
    { "source": "engagement.off", "event": "hover.leave" }
  ]
}
